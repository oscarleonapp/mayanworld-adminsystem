  "shortcuts": [
    {
      "name": "Tours Mayas",
      "short_name": "Tours",
      "description": "Explora Tikal, Yaxha y más sitios arqueológicos",
      "url": "/travel-agency-mvp/public/?route=tours"
    },
    {
      "name": "Mis Reservas",
      "short_name": "Reservas",
      "description": "Ver y gestionar mis reservas",
      "url": "/travel-agency-mvp/public/?route=profile"
    },
    {
      "name": "WhatsApp",
      "short_name": "WhatsApp",
      "description": "Contacto directo por WhatsApp",
      "url": "/travel-agency-mvp/public/?route=chat"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+travelmayanworld",
      "url": "/travel-agency-mvp/public/?route=booking&tour_id=%s"
    }
  ],
  "share_target": {
    "action": "/travel-agency-mvp/public/?route=share-destination",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/travel-agency-mvp/public/?route=import-booking",
      "accept": {
        "application/pdf": [".pdf"],
        "text/csv": [".csv"]
      }
    }
  ]
}
