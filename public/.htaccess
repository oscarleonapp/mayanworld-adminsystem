<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|webp|svg|woff2)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript image/svg+xml
</IfModule>

# Security headers (completas)
<IfModule mod_headers.c>
  # Prevenir MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Prevenir clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Control de referrer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Protección XSS (navegadores antiguos)
  Header always set X-XSS-Protection "1; mode=block"

  # Content Security Policy (CSP)
  # Ajustar según necesidades específicas de la aplicación
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://code.jquery.com https://js.stripe.com https://unpkg.com https://cdn.quilljs.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://unpkg.com https://cdn.quilljs.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; img-src 'self' data: https: http: https://*.openstreetmap.org; connect-src 'self' https://api.stripe.com https://cdn.jsdelivr.net https://nominatim.openstreetmap.org https://unpkg.com; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';"

  # Permissions Policy (Feature-Policy)
  Header always set Permissions-Policy "geolocation=(self), microphone=(), camera=(), payment=(self)"

  # HSTS (solo en producción con HTTPS)
  # Se activa automáticamente en producción (no en localhost)
  <If "%{HTTP_HOST} !~ /localhost/ && %{HTTP_HOST} !~ /127\.0\.0\.1/">
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
  </If>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ==========================================
  # HTTPS ENFORCEMENT (Auto-detecta producción)
  # ==========================================
  # Forzar HTTPS automáticamente en producción (no en localhost)
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Forzar www (opcional - descomentar si se desea)
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteCond %{HTTP_HOST} !^localhost [NC]
  # RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ==========================================
  # LEGACY URL REDIRECTS
  # ==========================================
  # Redirección permanente de la ruta antigua product/list a products
  RewriteCond %{QUERY_STRING} (^|&)route=product/list(&|$)
  RewriteRule ^.*$ /?route=products [R=301,L]

  # Otras rutas legacy equivalentes al listado
  RewriteCond %{QUERY_STRING} (^|&)route=products/list(&|$) [NC]
  RewriteRule ^.*$ /?route=products [R=301,L]

  RewriteCond %{QUERY_STRING} (^|&)route=product/index(&|$) [NC]
  RewriteRule ^.*$ /?route=products [R=301,L]

  RewriteCond %{QUERY_STRING} (^|&)route=products/index(&|$) [NC]
  RewriteRule ^.*$ /?route=products [R=301,L]

  # Rutas genéricas sin sufijo que apunten a producto sin id
  RewriteCond %{QUERY_STRING} (^|&)route=product(&|$) [NC]
  RewriteRule ^.*$ /?route=products [R=301,L]

  # Redirecciones a detalle unificado
  RewriteCond %{QUERY_STRING} ^route=products/detail/([A-Za-z0-9_-]+)$ [NC]
  RewriteRule ^.*$ /?route=product/%1 [R=301,L]
  RewriteCond %{QUERY_STRING} ^route=products/([A-Za-z0-9_-]+)$ [NC]
  RewriteRule ^.*$ /?route=product/%1 [R=301,L]

  # ==========================================
  # FRONT CONTROLLER (Manejo de todas las solicitudes)
  # ==========================================
  # Si la solicitud no es para un archivo o directorio existente,
  # la reescribe a index.php con la ruta como parámetro 'route'.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>
