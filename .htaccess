# ============================================
# Travel Agency MVP - .htaccess Multi-Entorno
# Auto-detecta Local vs Producción
# ============================================
#
# CONFIGURACIÓN DEL SUBDIRECTORIO LOCAL:
# Si tu proyecto está en un subdirectorio diferente a 'travel-agency-mvp',
# cambia el valor de LOCAL_SUBDIR en la línea SetEnvIf abajo.
# En producción (raíz del dominio), no necesitas cambiar nada.
# ============================================

# Protección de archivos sensibles
<FilesMatch "^(config\.local\.php|config\.production\.php|\.env|\.git.*|composer\.(json|lock)|package(-lock)?\.json)$">
    Require all denied
</FilesMatch>

# Proteger archivos SQL
<FilesMatch "\.(sql|sql\.gz|sql\.zip)$">
    Require all denied
</FilesMatch>

# Proteger archivos de backup
<FilesMatch "\.(bak|backup|old|tmp)$">
    Require all denied
</FilesMatch>

# Denegar acceso a directorios
Options -Indexes

# Proteger archivos de logs
<FilesMatch "\.log$">
    Require all denied
</FilesMatch>

# Proteger directorios sensibles (app, vendor, sql, logs, etc.)
RedirectMatch 403 ^/(app|sql|logs|backups|storage|scripts|tests|vendor|node_modules|_ARCHIVED|\.git)(/|$)

# ============================================
# CONFIGURACIÓN DE SUBDIRECTORIO LOCAL
# ============================================
# Cambia 'travel-agency-mvp' si tu proyecto está en otro subdirectorio
SetEnvIf Host .* LOCAL_SUBDIR=mayanworld-adminsystem

# ============================================
# REWRITE RULES - Auto-Detección de Entorno
# ============================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ==========================================
    # DETECCIÓN AUTOMÁTICA DE ENTORNO
    # ==========================================

    # Si es localhost (desarrollo local)
    RewriteCond %{HTTP_HOST} ^localhost$ [OR]
    RewriteCond %{HTTP_HOST} ^127\.0\.0\.1$
    RewriteRule .* - [E=IS_LOCAL:1]

    # ==========================================
    # REGLAS DE ASSETS Y UPLOADS - Local
    # ==========================================

    # Redirigir /assets/* a /public/assets/* (LOCALHOST)
    RewriteCond %{ENV:IS_LOCAL} =1
    RewriteRule ^assets/(.*)$ /%{ENV:LOCAL_SUBDIR}/public/assets/$1 [L]

    # Redirigir /uploads/* a /public/uploads/* (LOCALHOST)
    RewriteCond %{ENV:IS_LOCAL} =1
    RewriteRule ^uploads/(.*)$ /%{ENV:LOCAL_SUBDIR}/public/uploads/$1 [L]

    # ==========================================
    # REGLAS DE ASSETS Y UPLOADS - Producción
    # ==========================================

    # Redirigir /assets/* a /public/assets/* (PRODUCCIÓN)
    RewriteCond %{ENV:IS_LOCAL} !=1
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]

    # Redirigir /uploads/* a /public/uploads/* (PRODUCCIÓN)
    RewriteCond %{ENV:IS_LOCAL} !=1
    RewriteRule ^uploads/(.*)$ public/uploads/$1 [L]

    # ==========================================
    # FRONT CONTROLLER - Común para ambos
    # ==========================================

    # Permitir acceso a archivos reales
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Permitir acceso a directorios reales
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ==========================================
    # REDIRIGIR A INDEX.PHP - Local
    # ==========================================

    RewriteCond %{ENV:IS_LOCAL} =1
    RewriteRule ^(.*)$ /%{ENV:LOCAL_SUBDIR}/index.php?route=$1 [QSA,L]

    # ==========================================
    # REDIRIGIR A INDEX.PHP - Producción
    # ==========================================

    RewriteCond %{ENV:IS_LOCAL} !=1
    RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]
</IfModule>

# ============================================
# FORZAR HTTPS (Solo en Producción)
# ============================================
<IfModule mod_rewrite.c>
    # Solo forzar HTTPS si NO es localhost
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ============================================
# CACHE Y OPTIMIZACIÓN
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 month"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/javascript image/svg+xml
</IfModule>

# ============================================
# SECURITY HEADERS
# ============================================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>
